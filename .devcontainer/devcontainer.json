{
  "name": "nursecall-anomaly-reproducibility",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    },
    "codespaces": {
      "openFiles": [
        "README.md",
        "src/experiment_v2.py",
        "src/experiment_synth_v2.py"
      ]
    }
  },
  "forwardPorts": [
    8501
  ],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit demonstration",
      "onAutoForward": "notify"
    }
  }
}
